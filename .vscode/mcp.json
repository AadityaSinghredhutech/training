{
	"servers": {
		"playwright": {
			"type": "stdio",
			"sandboxEnabled": false,
			"command": "npx",
			"cwd": "${input:cwd}",
			"args": [
				"@playwright/mcp@0.0.75"
			],
			"env": {}
		}
	},
	"inputs": [
		{
			"id": "cwd",
			"type": "promptString",
			"description": "Working Directory"
		}
	]
}